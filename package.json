{
  "name": "discord-schedule-matching-bot",
  "version": "0.0.1",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "bun vitest",
    "test:ui": "bun vitest --ui",
    "lint": "biome lint src/ tests/",
    "format": "biome format --write src/ tests/",
    "format:check": "biome format src/ tests/",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "discord-api-types": "^0.37.109",
    "discord-interactions": "^4.4.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.6.10",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@cloudflare/vitest-pool-workers": "^0.12.4",
    "@cloudflare/workers-types": "^4.20260116.0",
    "@vitest/ui": "^3.2.4",
    "drizzle-kit": "^0.30.1",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4",
    "wrangler": "^3.92.0"
  },
  "type": "module"
}
